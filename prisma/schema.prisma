// SONDA — Prisma schema
//
// Data model for SONDA's review pipeline. Persists each investigation
// as a `ReviewSession` (the durable request and its current state),
// the per-reviewer `ReviewerResult` rows (one per juror in the
// multi-agent panel), and the eventual `ReviewResult` (the final
// jury verdict). Designed to be source-agnostic so the same tables
// can back Public Website, GitHub, ZIP, and Private Website reviews
// — the per-source collectors live in `features/<source>-review/`
// and are not coupled to this schema.
//
// Database
//   - PostgreSQL in production (Neon recommended for serverless).
//   - The same engine is used in tests.
//
// Generator
//   - Output is the default `node_modules/.prisma/client`. Import the
//     typed client from `@/lib/db` (singleton) so dev hot-reload does
//     not spawn a new client per request.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

// `ReviewType` — the source the user submitted.
//
// Aligned with `types/evidence.ts#ReviewSource`:
//   WEBSITE          ↔  'website'
//   GITHUB           ↔  'github'
//   ZIP              ↔  'zip'
//   PRIVATE_WEBSITE  ↔  'private'
enum ReviewType {
  WEBSITE
  GITHUB
  ZIP
  PRIVATE_WEBSITE
}

// `ReviewStatus` — the lifecycle of a single investigation.
//
//   PENDING      Created, not yet picked up by a worker.
//   RUNNING      An analyzer (browser / GitHub / ZIP / private) is
//                actively producing evidence.
//   COMPLETED    ReviewResult row attached; the jury has spoken.
//   FAILED       The investigation could not be completed. The
//                reason lives in the API/worker logs for this task;
//                a dedicated failure column will land with the
//                first analyzer.
enum ReviewStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// `ReviewerType` — the juror that produced a `ReviewerResult`.
//
// Aligned with `agents/types.ts#ReviewerId`:
//   QA           ↔  'qa'
//   UX           ↔  'ux'
//   MARKETING    ↔  'marketing'
//   INVESTOR     ↔  'investor'
//   JUDGE        ↔  'judge'
//   FIRST_USER   ↔  'first-user'
//
// A given `ReviewSession` is expected to accumulate exactly one
// row per juror; the unique index on `(sessionId, reviewer)`
// enforces that invariant at the database level.
enum ReviewerType {
  QA
  UX
  MARKETING
  INVESTOR
  JUDGE
  FIRST_USER
}

// `PriorityFixEffort` — how much work a suggested fix requires.
//
// Aligned with the `effort` field on `agents/types.ts#PriorityFix`
// ('low' | 'medium' | 'high'). The model stores the full fix
// object as a JSON blob (see `ReviewerResult.priorityFixes`); this
// enum is the source of truth that JSON values must conform to on
// the application side.
enum PriorityFixEffort {
  LOW
  MEDIUM
  HIGH
}

// `PriorityFixImpact` — how much a suggested fix moves the needle.
//
// Aligned with the `impact` field on `agents/types.ts#PriorityFix`
// ('low' | 'medium' | 'high'). Same role as `PriorityFixEffort`:
// the enum documents the contract; the actual fix data lives in
// `ReviewerResult.priorityFixes` as JSON.
enum PriorityFixImpact {
  LOW
  MEDIUM
  HIGH
}

// -----------------------------------------------------------------------------
// Models
// -----------------------------------------------------------------------------

// `ReviewSession` — one investigation request, end-to-end.
//
// `target` is intentionally a free-form `String`:
//   - For WEBSITE / PRIVATE_WEBSITE: the URL the user submitted.
//   - For GITHUB:                    the full `https://github.com/owner/repo` URL.
//   - For ZIP:                       a reference to the uploaded artifact
//                                   (e.g. an object-storage key); the upload
//                                   flow is wired up in a later task, so for
//                                   now the API just stores the user-supplied
//                                   label verbatim.
//
// `userId` is optional because authentication is not part of this task.
// When auth lands (NextAuth) we add a `User` model and a relation here.
model ReviewSession {
  id        String       @id @default(cuid())
  userId    String?
  type      ReviewType
  status    ReviewStatus @default(PENDING)
  target    String
  /// Normalized evidence bundle produced by the source-specific
  /// collector. Stored as JSONB. Nullable because not every
  /// session has a real collector yet (the placeholders leave
  /// this null).
  evidence  Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  result          ReviewResult?
  reviewerResults ReviewerResult[]

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("review_sessions")
}

// `ReviewerResult` — one row per juror in the multi-agent panel.
//
// Persists the structured output a single reviewer agent produced
// for a given `ReviewSession`. Created when that reviewer finishes
// its investigation; the orchestrator writes rows as the agents
// complete (out of order is fine). The verdict engine then
// aggregates all `ReviewerResult` rows for a session into the
// single `ReviewResult.verdict` row.
//
// Field mapping (vs. `agents/types.ts#ReviewerOutput`):
//   reviewer        → `ReviewerType` enum
//   score           → `Int` (0–100)
//   confidence      → `Float` (0–1)
//   summary         → `String`
//   strengths       → `String[]` (PostgreSQL `text[]`)
//   weaknesses      → `String[]` (PostgreSQL `text[]`)
//   priorityFixes   → `Json` (array of `PriorityFix`-shaped objects)
//
// The unique index on `(sessionId, reviewer)` makes "one row per
// juror per session" a database-level invariant — the application
// can rely on it without re-checking.
model ReviewerResult {
  id            String       @id @default(cuid())
  sessionId     String
  reviewer      ReviewerType
  score         Int
  confidence    Float
  summary       String
  strengths     String[]
  weaknesses    String[]
  priorityFixes Json
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  session ReviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, reviewer])
  @@index([sessionId])
  @@index([reviewer])
  @@index([createdAt])
  @@map("reviewer_results")
}

// `ReviewResult` — the jury's final verdict for a `ReviewSession`.
//
// Created only when the orchestrator finishes collecting evidence and
// every reviewer has produced an output. Until then, no row exists.
//
// `verdict` is the categorical decision (`ship` / `refine` / `hold` or
// whatever the verdict engine lands on). It is stored as a `String`
// rather than an enum to keep this task's schema stable; the verdict
// engine will own the enum on the application side.
//
// `summary` is the human-readable headline + a longer write-up. Kept
// in a single `Text` column for now; a normalized `summary` + `body`
// split can be added later without a breaking schema change.
model ReviewResult {
  id           String   @id @default(cuid())
  sessionId    String   @unique
  overallScore Int
  verdict      String
  summary      String
  createdAt    DateTime @default(now())

  session ReviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("review_results")
}
