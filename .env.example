# =============================================================================
# SONDA — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# Never commit secrets. `.env*` is git-ignored.
# =============================================================================

# --- AI / LLM -----------------------------------------------------------------
# Used by every AI reviewer (QA, UX, Marketing, Investor, Judge, First-User)
OPENAI_API_KEY=

# --- Database -----------------------------------------------------------------
# PostgreSQL connection string. Neon recommended for serverless.
# Example (Neon):  postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/sonda?sslmode=require
# Example (local):  postgresql://postgres:postgres@localhost:5432/sonda
DATABASE_URL=

# --- Auth (planned) -----------------------------------------------------------
# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Optional integrations ----------------------------------------------------
# GitHub personal access token — raises rate limits when analyzing public repos.
# Not required for the MVP. Do not use a token with private-repo scopes.
GITHUB_TOKEN=

# --- Playwright (private-site auth, post-MVP) ---------------------------------
# PLAYWRIGHT_BROWSERS_PATH=0
